generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Staff {
  id             String    @id @default(uuid())
  name           String
  pin            String    // bcrypt hash
  rank           Int       // 0-7
  permissions    Json?     // custom rank overrides
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  sessions       Session[]
  tabs           Tab[]
  orders         Order[]
  payments       Payment[]
  auditLogs      AuditLog[]
  dayCloses      DayClose[]

  @@index([pin])
}

model Session {
  id         String   @id @default(uuid())
  staffId    String
  terminalId String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  staff      Staff    @relation(fields: [staffId], references: [id])
}

model Table {
  id        String    @id @default(uuid())
  number    Int       @unique
  name      String?
  zone      String?
  seats     Int       @default(2)
  posX      Float     @default(0)
  posY      Float     @default(0)
  status    String    @default("AVAILABLE") // AVAILABLE | OCCUPIED | AWAITING_FOOD | READY | PAID | RESERVED | DIRTY
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tabs      Tab[]
}

model Tab {
  id         String    @id @default(uuid())
  tableId    String?
  name       String?
  allergens  Json?     // array of strings
  guestCount Int?
  status     String    @default("OPEN") // OPEN | CLOSED
  staffId    String
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  table     Table?    @relation(fields: [tableId], references: [id])
  staff     Staff     @relation(fields: [staffId], references: [id])
  orders    Order[]
  payments  Payment[]

  @@index([tableId, status])
}

model Order {
  id            String    @id @default(uuid())
  tabId         String
  orderNumber   Int       @default(autoincrement())
  status        String    @default("DRAFT") // DRAFT | SUBMITTED | PREPARING | READY | SERVED | CLOSED | VOID
  priority      Boolean   @default(false)
  notes         String?
  staffId       String
  discountType  String?   // PERCENT | FIXED
  discountValue Decimal?  @db.Decimal(10, 2)
  subtotal      Decimal   @default(0) @db.Decimal(10, 2)
  total         Decimal   @default(0) @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  submittedAt   DateTime?
  closedAt      DateTime?
  updatedAt     DateTime  @updatedAt

  tab           Tab         @relation(fields: [tabId], references: [id])
  staff         Staff       @relation(fields: [staffId], references: [id])
  items         OrderItem[]

  @@index([status, createdAt])
}

model OrderItem {
  id           String    @id @default(uuid())
  orderId      String
  menuItemId   String
  name         String    // snapshot
  price        Decimal   @db.Decimal(10, 2) // snapshot
  quantity     Int       @default(1)
  modifiers    Json?
  notes        String?
  status       String    @default("PENDING") // PENDING | IN_PROGRESS | DONE | SERVED | VOID
  kdsStation   String?   // which KDS station this routes to
  kdsStatus    String    @default("PENDING") // PENDING | IN_PROGRESS | DONE | SERVED
  startedAt    DateTime? // when kitchen started preparing
  completedAt  DateTime? // when kitchen marked done
  servedAt     DateTime? // when marked as served/picked up
  voidReason   String?
  voidedBy     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem     MenuItem  @relation(fields: [menuItemId], references: [id])

  @@index([kdsStatus, createdAt])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  sortOrder Int       @default(0)
  colour    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items     MenuItem[]
}

model MenuItem {
  id             String    @id @default(uuid())
  categoryId     String
  name           String
  price          Decimal   @db.Decimal(10, 2)
  description    String?
  colour         String?
  sortOrder      Int       @default(0)
  modifierGroups Json?
  kdsStation     String?   // default KDS station for this item
  isAvailable    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  category       Category  @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]

  @@index([categoryId, deletedAt])
}

model Payment {
  id                String   @id @default(uuid())
  tabId             String
  method            String   // CASH | CARD | OTHER
  type              String   @default("PAYMENT") // PAYMENT | REFUND
  amount            Decimal  @db.Decimal(10, 2)
  tipAmount         Decimal  @default(0) @db.Decimal(10, 2)
  changeGiven       Decimal? @db.Decimal(10, 2)
  reference         String?
  refundReason      String?
  originalPaymentId String?
  staffId           String
  processedAt       DateTime @default(now())
  createdAt         DateTime @default(now())

  tab               Tab      @relation(fields: [tabId], references: [id])
  staff             Staff    @relation(fields: [staffId], references: [id])

  @@index([type])
}

model AuditLog {
  id           String   @id @default(uuid())
  staffId      String
  terminalId   String
  action       String
  entityType   String
  entityId     String
  previousData Json?
  newData      Json?
  metadata     Json?
  orderId      String?
  timestamp    DateTime @default(now())

  staff        Staff    @relation(fields: [staffId], references: [id])

  @@index([entityType, entityId])
  @@index([orderId])
  @@index([staffId, timestamp])
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model KdsStation {
  id        String   @id @default(uuid())
  name      String   @unique  // e.g. "Grill", "Bar", "Fryer", "Pass"
  colour    String?  // display colour
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DayClose {
  id           String   @id @default(uuid())
  date         DateTime @unique
  staffId      String
  openingCash  Decimal  @db.Decimal(10, 2)
  closingCash  Decimal  @db.Decimal(10, 2)
  expectedCash Decimal  @db.Decimal(10, 2)
  variance     Decimal  @db.Decimal(10, 2)
  totalSales   Decimal  @db.Decimal(10, 2)
  totalRefunds Decimal  @db.Decimal(10, 2)
  totalTips    Decimal  @db.Decimal(10, 2)
  totalVoids   Int      @default(0)
  orderCount   Int      @default(0)
  coverCount   Int      @default(0)
  lostItems    Json?
  reportData   Json
  closedAt     DateTime @default(now())

  staff        Staff    @relation(fields: [staffId], references: [id])

  @@index([date])
}
