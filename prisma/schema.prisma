generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Staff {
  id             String    @id @default(uuid())
  name           String
  pin            String    // bcrypt hash
  rank           Int       // 0-7
  permissions    Json?     // custom rank overrides
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  sessions       Session[]
  tabs           Tab[]
  orders         Order[]
  payments       Payment[]
  auditLogs      AuditLog[]

  @@index([pin])
}

model Session {
  id         String   @id @default(uuid())
  staffId    String
  terminalId String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  staff      Staff    @relation(fields: [staffId], references: [id])
}

model Table {
  id        String    @id @default(uuid())
  number    Int       @unique
  name      String?
  zone      String?
  seats     Int       @default(2)
  posX      Float     @default(0)
  posY      Float     @default(0)
  status    String    @default("AVAILABLE") // AVAILABLE | OCCUPIED | RESERVED | DIRTY
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tabs      Tab[]
}

model Tab {
  id        String    @id @default(uuid())
  tableId   String?
  name      String?
  allergens Json?     // array of strings
  status    String    @default("OPEN") // OPEN | CLOSED
  staffId   String
  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  table     Table?    @relation(fields: [tableId], references: [id])
  staff     Staff     @relation(fields: [staffId], references: [id])
  orders    Order[]
  payments  Payment[]

  @@index([tableId, status])
}

model Order {
  id            String    @id @default(uuid())
  tabId         String
  orderNumber   Int       @default(autoincrement())
  status        String    @default("DRAFT") // DRAFT | SUBMITTED | PREPARING | READY | SERVED | CLOSED | VOID
  priority      Boolean   @default(false)
  notes         String?
  staffId       String
  discountType  String?   // PERCENT | FIXED
  discountValue Decimal?  @db.Decimal(10, 2)
  subtotal      Decimal   @default(0) @db.Decimal(10, 2)
  total         Decimal   @default(0) @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  submittedAt   DateTime?
  closedAt      DateTime?
  updatedAt     DateTime  @updatedAt

  tab           Tab         @relation(fields: [tabId], references: [id])
  staff         Staff       @relation(fields: [staffId], references: [id])
  items         OrderItem[]

  @@index([status, createdAt])
}

model OrderItem {
  id           String    @id @default(uuid())
  orderId      String
  menuItemId   String
  name         String    // snapshot
  price        Decimal   @db.Decimal(10, 2) // snapshot
  quantity     Int       @default(1)
  modifiers    Json?
  notes        String?
  status       String    @default("PENDING") // PENDING | VOID
  voidReason   String?
  voidedBy     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem     MenuItem  @relation(fields: [menuItemId], references: [id])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  sortOrder Int       @default(0)
  colour    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  items     MenuItem[]
}

model MenuItem {
  id             String    @id @default(uuid())
  categoryId     String
  name           String
  price          Decimal   @db.Decimal(10, 2)
  description    String?
  colour         String?
  sortOrder      Int       @default(0)
  modifierGroups Json?
  isAvailable    Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  category       Category  @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]

  @@index([categoryId, deletedAt])
}

model Payment {
  id          String   @id @default(uuid())
  tabId       String
  method      String   // CASH | CARD | OTHER
  amount      Decimal  @db.Decimal(10, 2)
  tipAmount   Decimal  @default(0) @db.Decimal(10, 2)
  changeGiven Decimal? @db.Decimal(10, 2)
  reference   String?
  staffId     String
  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  tab         Tab      @relation(fields: [tabId], references: [id])
  staff       Staff    @relation(fields: [staffId], references: [id])
}

model AuditLog {
  id           String   @id @default(uuid())
  staffId      String
  terminalId   String
  action       String
  entityType   String
  entityId     String
  previousData Json?
  newData      Json?
  metadata     Json?
  orderId      String?
  timestamp    DateTime @default(now())

  staff        Staff    @relation(fields: [staffId], references: [id])

  @@index([entityType, entityId])
  @@index([orderId])
  @@index([staffId, timestamp])
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}
