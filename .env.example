DATABASE_URL="postgresql://user:pass@db.xxx.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@db.xxx.supabase.co:5432/postgres"

# JWT secret (generate a secure random string)
JWT_SECRET="changeme-random-secret-key-at-least-32-chars-long"

# Auth configuration
PIN_MAX_ATTEMPTS=5
# Lockout time in minutes after max failed attempts
LOCKOUT_DURATION_MINUTES=5
# Inactivity timer in minutes on the frontend (auto-lock terminal)
SESSION_TIMEOUT_MINUTES=5
